---
// Libraries and Packages
import {Image} from "astro:assets";

// Internal Components and Assets
import aboutImage from "@images/frontend-dev-working-4-tinted-removebg-preview-cropped.png";

// Styles
import "./TheAbout.scss";
---

<section id="about" class="[ about ] [ section ]">
    <div class="[ about__container ] [ even-columns ]">
        <Image
            class="[ image-background ] [ inline-center ]"
            src={aboutImage}
            alt=""
            format="png"
            data-aos="fade-left"
            data-aos-offset="250"
            data-aos-duration="2000"
        />
        <div class="flow" data-aos="fade-right" data-aos-offset="150">
            <div>
                <h2 class="caption">About</h2>
                <p class="heading-2">
                    Solution Engineer based in Brussels, Belgium&nbsp;📍
                </p>
            </div>
            <p>
                I work at the intersection of solution design, functional
                analysis, and full-stack development, turning complex
                requirements into well-structured, maintainable technical
                solutions. My background blends hands-on engineering with
                architecture thinking and end-to-end project delivery. I enjoy
                working on projects where technology serves a meaningful
                purpose.
            </p>
            <a
                href="/cv-ivan-rodrigues.pdf"
                class="button mt-lg"
                target="_blank">Download CV</a
            >
        </div>
    </div>
</section>
